# ============================================================
# SOVEREIGN OMEGA — Environment Configuration
# Copy this file to .env and fill in required values.
# Never commit .env to version control.
# ============================================================

# ─── API Keys ────────────────────────────────────────────────
# DashScope API key (Track B products — buyer-provided in production)
VITE_DASHSCOPE_KEY=your_dashscope_api_key_here
VITE_DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
VITE_DASHSCOPE_MODEL=qwen-plus

# ─── Runtime Configuration ───────────────────────────────────
# Schema version (must match RuntimeVersionPin in application code)
VITE_SCHEMA_VERSION=1.0.0
VITE_PROJECTION_COMPILER_VERSION=1.0.0
VITE_CALIBRATION_MODEL_VERSION=1.0.0

# ─── VCG Calibration ─────────────────────────────────────────
VITE_VCG_WINDOW_SIZE=500
VITE_VCG_MIN_GATE_WINDOW=100
VITE_VCG_ALERT_THRESHOLD=0.35
VITE_VCG_SUSPEND_THRESHOLD=0.50

# ─── Risk Budget ─────────────────────────────────────────────
VITE_RISK_BUDGET_GLOBAL=1.0
VITE_RISK_BUDGET_MAX_ROUNDS=1000
VITE_RISK_BUDGET_DECAY_LAMBDA=0.0000000139  # 0.05 per hour in ms

# ─── E1 Ambiguity Routing ────────────────────────────────────
VITE_AMBIGUITY_DIVERGENCE_THRESHOLD=0.65
VITE_GROUNDING_CONFIDENCE_FLOOR=0.40
VITE_MAX_CLARIFICATION_RATE=0.333

# ─── Gate Parameters ─────────────────────────────────────────
VITE_GATE_ALPHA=0.05          # Significance level for Bernstein bounds
VITE_GATE_RHO=0.5             # Mixing parameter for confidence sequence

# ─── Deployment ──────────────────────────────────────────────
VITE_APP_VERSION=0.5.3
VITE_STREAM_ID=sovereign-main

# ─── KMS Configuration (production only) ────────────────────
# Required before GDPR tombstoning can be used in production.
# The tombstone.ts stub will not shred keys without these values.
KMS_ENDPOINT=
KMS_KEY_ID=
KMS_REGION=

# ─── Vercel ──────────────────────────────────────────────────
# Set these in Vercel dashboard, not here
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
