{
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(tsx:*)",
      "Bash(tsc:*)",
      "Bash(vitest:*)",
      "Bash(zip:*)",
      "Bash(git:*)",
      "Bash(sha256sum:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(cargo:*)",
      "Bash(cargo test*)",
      "Bash(cargo build*)",
      "Bash(python3:*)",
      "Bash(curl:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(rustc --version)",
      "Read(**)",
      "Write(src/**)",
      "Write(test/**)",
      "Write(scripts/**)",
      "Write(.claude/**)",
      "Write(docs/**)",
      "Write(.env.example)"
    ],
    "deny": [
      "Write(gate.py)",
      "Write(dna.py)",
      "Write(router.py)",
      "Write(docs/SOVEREIGN_OMEGA_INTEGRATED_SPEC_v2.md)",
      "Write(ARTIFACT_REGISTRY.md)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-frozen-writes.sh \"$CLAUDE_TOOL_INPUT_PATH\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tier-check.sh \"$CLAUDE_TOOL_INPUT_PATH\""
          }
        ]
      }
    ]
  },
  "env": {
    "NODE_ENV": "test"
  },
  "includeCoAuthoredBy": true
}
