# AEGIS-Ω Cockpit — Environment Variables
#
# === Cloud Run / Vertex AI (production) ===
# Set as Cloud Run env vars — service account handles auth automatically.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_REGION=europe-west3

# === Server config (Cloud Run) ===
PORT=8080
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=2048
RATE_LIMIT_RPM=20

# === Local dev: direct Anthropic API ===
# ANTHROPIC_API_KEY=sk-ant-...

# === Frontend build-time vars ===
# Empty in production (same-origin server handles /claude/stream)
VITE_BRIDGE_URL=

# Local dev: point at bridge.py or local server
# VITE_BRIDGE_URL=http://localhost:7890

# Fallback inference routes (buyer supplies keys)
VITE_DASHSCOPE_API_KEY=
VITE_DASHSCOPE_MODEL=qwen-plus
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=hermes3:8b

# Observational analytics (PostHog)
VITE_POSTHOG_KEY=
