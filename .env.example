# AEGIS-- root environment template
# Copy to .env before running docker compose or local bridge services.

# Required for the Python bridge (/claude endpoint) and cockpit server fallback.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: multi-model / external provider configuration.
OPENAI_API_KEY=sk-...
QWEN_API_KEY=...
DASHSCOPE_API_KEY=...

# Bridge configuration.
SOVEREIGN_BRIDGE_PORT=7890
AEGIS_CHECKPOINT_PATH=/app/data/aegis_checkpoint.json
AEGIS_GOSSIP_UDP_PORT=9090

# Cockpit / Studio / shared frontend bridge URL for local development.
VITE_BRIDGE_URL=http://localhost:7890

# Supabase integrations.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
